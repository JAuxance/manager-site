---
interface Props {
  label?: string;   // si fourni, override ; sinon, label bilingue auto
}
const { label } = Astro.props;
---

<div class="cue" data-scroll-cue>
  {label ? (
    <span class="cue__label">{label}</span>
  ) : (
    <span class="cue__label">
      <span data-lang="en">Scroll</span>
      <span data-lang="fr">Faire défiler</span>
    </span>
  )}
  <span class="cue__line" aria-hidden="true"></span>
</div>

<style>
  .cue {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cue__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  .cue__line {
    position: relative;
    width: 1px;
    height: 64px;
    background: var(--rule);
    overflow: hidden;
  }

  .cue__line::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: -60%;
    height: 60%;
    background: var(--ink);
    animation: cue-fall 2.4s var(--ease-editorial) infinite;
  }

  @keyframes cue-fall {
    0%   { transform: translateY(0);     opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(260%);  opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cue__line::after { animation: none; display: none; }
  }
</style>
