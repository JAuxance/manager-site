---
// § 7b — Changelog
// Liste des 5 dernières releases GitHub, tirée au build via releases.ts.
// Si l'API est injoignable, la section ne rend rien (silencieusement).

import { getReleaseList } from "~/lib/releases";

const releases = await getReleaseList(5);

// Helpers locaux : format de date "15 Apr 2026" / "15 avr. 2026"
// et extraction des ~3 premières bullet points du body markdown.
function firstBullets(body: string, max = 3): string[] {
  if (!body) return [];
  return body
    .split("\n")
    .map((l) => l.trim())
    .filter((l) => /^[-*•]\s+/.test(l))
    .slice(0, max)
    .map((l) => l.replace(/^[-*•]\s+/, "").replace(/\s+/g, " ").trim());
}

function formatDate(iso: string, lang: "en" | "fr"): string {
  if (!iso) return "—";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  return d.toLocaleDateString(lang === "fr" ? "fr-FR" : "en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}
---

{releases.length > 0 && (
  <section class="changelog" id="changelog" data-changelog>
    <div class="changelog__head">
      <span class="eyebrow" data-appear>
        <span data-lang="en">Changelog</span>
        <span data-lang="fr">Journal des versions</span>
      </span>

      <h2 class="changelog__title" data-appear data-appear-delay="120">
        <span data-lang="en">The tool, <em>kept sharp.</em></span>
        <span data-lang="fr">L'outil, <em>entretenu.</em></span>
      </h2>

      <p class="changelog__lede" data-appear data-appear-delay="240">
        <span data-lang="en">Live from the release feed. Every ship, every fix.</span>
        <span data-lang="fr">Directement du feed des releases. Chaque version, chaque fix.</span>
      </p>
    </div>

    <ol class="changelog__list" data-appear-group>
      {releases.map((r) => {
        const bullets = firstBullets(r.body);
        return (
          <li class="changelog__entry" data-appear>
            <a
              class="changelog__link"
              href={r.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="changelog__entry-head">
                <span class="changelog__version">v{r.version}</span>
                <span class="changelog__dates">
                  <time class="changelog__date" datetime={r.date} data-lang="en">
                    {formatDate(r.date, "en")}
                  </time>
                  <time class="changelog__date" datetime={r.date} data-lang="fr">
                    {formatDate(r.date, "fr")}
                  </time>
                </span>
              </div>

              <p class="changelog__entry-title">{r.title}</p>

              {bullets.length > 0 && (
                <ul class="changelog__bullets">
                  {bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              )}

              <span class="changelog__cta" aria-hidden="true">
                <span data-lang="en">Read notes</span>
                <span data-lang="fr">Lire les notes</span>
                <span class="changelog__arrow">→</span>
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
)}

<style>
  .changelog {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: clamp(5rem, 8vw, 8rem) var(--gutter);
  }

  /* --- Head --- */
  .changelog__head {
    max-width: var(--col-max);
    margin: 0 auto clamp(3rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .changelog__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw + 0.5rem, 4.5rem);
    font-weight: 200;
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
    max-width: 18ch;
  }
  .changelog__title em { font-style: italic; color: var(--mute); }
  .changelog__lede {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.75vw + 0.8rem, 1.4rem);
    font-style: italic;
    color: var(--mute);
  }

  /* --- List --- */
  .changelog__list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--col-max);
    margin-inline: auto;
    border-top: 1px solid var(--rule);
  }

  .changelog__entry {
    border-bottom: 1px solid var(--rule);
  }

  .changelog__link {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr) auto;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: baseline;
    padding: clamp(1.5rem, 3vw, 2.25rem) var(--space-4);
    margin-inline: calc(var(--space-4) * -1);
    text-decoration: none;
    color: var(--ink);
    transition: color var(--dur-base) var(--ease-out);
  }
  .changelog__link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--ink);
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform var(--dur-base) var(--ease-editorial);
  }
  .changelog__link:hover::before { transform: scaleY(1); }
  .changelog__link:hover .changelog__arrow { transform: translateX(6px); }

  .changelog__entry-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .changelog__version {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.5vw + 0.75rem, 2rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
  }
  .changelog__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  .changelog__entry-title {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 0.5vw + 0.95rem, 1.4rem);
    line-height: 1.4;
    margin: 0 0 var(--space-3);
    color: var(--ink);
    max-width: 46ch;
  }

  .changelog__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: 50ch;
  }
  .changelog__bullets li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--mute);
    padding-left: var(--space-4);
    position: relative;
  }
  .changelog__bullets li::before {
    content: "·";
    position: absolute;
    left: var(--space-2);
    color: var(--ink);
  }

  .changelog__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
    align-self: center;
  }
  .changelog__arrow {
    display: inline-block;
    transition: transform var(--dur-base) var(--ease-editorial);
  }

  @media (max-width: 860px) {
    .changelog__link {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .changelog__entry-head {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
    }
    .changelog__cta { justify-self: flex-start; }
  }
</style>
