---
// § 03 — Count the days
// Grille 30 cases qui se remplissent au scroll.

const DAYS = 30;
const squares = Array.from({ length: DAYS }, (_, i) => i);
---

<section class="count" data-count>
  <div class="count__sticky">
    <div class="count__grid">

      <div class="count__text">
        <span class="eyebrow count__eyebrow">Count the days</span>

        <h2 class="count__title">
          <span data-lang="en">Thirty days.<br /><em>Held.</em></span>
          <span data-lang="fr">Trente jours.<br /><em>Tenus.</em></span>
        </h2>

        <p class="count__lede">
          <span data-lang="en">One square per day. Filled or empty. Manager won't let you cheat.</span>
          <span data-lang="fr">Un carré par jour. Plein ou vide. Manager ne te laisse pas tricher.</span>
        </p>

        <div class="count__stat">
          <span class="count__stat-num" data-count-done>0</span>
          <span class="count__stat-sep">/</span>
          <span class="count__stat-total">{DAYS}</span>
          <span class="count__stat-label">
            <span data-lang="en">Days held</span>
            <span data-lang="fr">Jours tenus</span>
          </span>
        </div>
      </div>

      <div class="count__board" data-count-board>
        {squares.map((i) => (
          <span class="count__sq" data-count-sq data-idx={i}>
            <span class="count__sq-fill"></span>
          </span>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .count {
    position: relative;
    background: var(--paper);
    border-top: 1px solid var(--rule);
  }

  .count__sticky {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: var(--space-8) var(--gutter);
  }

  .count__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: center;
    gap: clamp(3rem, 7vw, 7rem);
    width: 100%;
    max-width: var(--col-max);
    margin: 0 auto;
  }

  /* --- Text column --- */
  .count__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 34rem;
  }
  .count__eyebrow { color: var(--mute); }

  .count__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw + 0.5rem, 6rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: var(--tracking-tight);
  }
  .count__title em { font-style: italic; color: var(--mute); }

  .count__lede {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1vw + 0.75rem, 1.6rem);
    line-height: 1.35;
    color: var(--mute);
    font-style: italic;
    max-width: 32ch;
  }

  .count__stat {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }

  .count__stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 3.5vw + 0.5rem, 3.75rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
  }
  .count__stat-sep,
  .count__stat-total {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2.25rem);
    color: var(--mute);
    font-weight: 200;
  }
  .count__stat-label {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    align-self: end;
  }

  /* --- Board 30 cases --- */
  .count__board {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(6px, 0.6vw, 10px);
    width: 100%;
    max-width: 460px;
    justify-self: center;
  }

  .count__sq {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--ink);
    overflow: hidden;
  }

  .count__sq-fill {
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform-origin: bottom center;
    transform: scaleY(0);
    will-change: transform;
  }

  @media (max-width: 860px) {
    .count__grid { grid-template-columns: 1fr; gap: var(--space-10, 2.5rem); }
    .count__board { max-width: 360px; }
  }
</style>
