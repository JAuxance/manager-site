---
import Logo from "~/components/Logo.astro";

const year = new Date().getFullYear();
---

<footer class="sitefooter" data-footer>
  <div class="sitefooter__grid">

    <div class="sitefooter__brand" data-appear>
      <div class="sitefooter__logo">
        <Logo />
      </div>
      <div class="sitefooter__brand-text">
        <span class="sitefooter__name">Manager</span>
        <span class="sitefooter__tag">Day counter · Focus · Journal</span>
      </div>
    </div>

    <nav class="sitefooter__nav" aria-label="Footer navigation" data-appear-group>
      <a href="#get-started" data-appear>
        <span data-lang="en">Get started</span>
        <span data-lang="fr">Commencer</span>
      </a>
      <a href="#work" data-appear>
        <span data-lang="en">Tools</span>
        <span data-lang="fr">Outils</span>
      </a>
      <a href="#focus" data-appear>Focus</a>
      <a href="#log" data-appear>
        <span data-lang="en">Journal</span>
        <span data-lang="fr">Journal</span>
      </a>
      <a href="/mentions-legales" data-appear>
        <span data-lang="en">Legal</span>
        <span data-lang="fr">Mentions&nbsp;légales</span>
      </a>
      <a href="/confidentialite" data-appear>
        <span data-lang="en">Privacy</span>
        <span data-lang="fr">Confidentialité</span>
      </a>
    </nav>

    <div class="sitefooter__close" data-appear data-appear-delay="200">
      <span class="sitefooter__maxim">
        <span data-lang="en">Hold. Count. Begin again.</span>
        <span data-lang="fr">Tiens. Compte. Recommence.</span>
      </span>
      <span class="sitefooter__legal">
        <span data-lang="en">© {year} · Manager · All rights reserved.</span>
        <span data-lang="fr">© {year} · Manager · Tous droits réservés.</span>
      </span>
    </div>

  </div>

  <div class="sitefooter__mark" aria-hidden="true" data-appear>
    <div class="sitefooter__bar"></div>
    <div class="sitefooter__bar"></div>
    <div class="sitefooter__bar"></div>
    <div class="sitefooter__bar"></div>
  </div>
</footer>

<style>
  .sitefooter {
    position: relative;
    background: var(--paper);
    border-top: 1px solid var(--ink);
    padding: clamp(3rem, 5vw, 4.5rem) var(--gutter) var(--space-8);
  }

  .sitefooter__grid {
    display: grid;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr) minmax(0, auto);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
    max-width: var(--col-max);
    margin: 0 auto;
  }

  /* --- Brand --- */
  .sitefooter__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .sitefooter__logo {
    width: 44px;
    height: 44px;
  }
  .sitefooter__brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sitefooter__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1;
  }
  .sitefooter__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  /* --- Nav --- */
  .sitefooter__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    align-self: center;
    justify-content: center;
  }
  .sitefooter__nav a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink);
    position: relative;
    padding: var(--space-3) var(--space-2);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .sitefooter__nav a::after {
    content: "";
    position: absolute;
    left: var(--space-2);
    right: var(--space-2);
    bottom: calc(var(--space-3) - 2px);
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .sitefooter__nav a:hover::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  /* --- Close block --- */
  .sitefooter__close {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-align: right;
    justify-self: end;
    align-items: flex-end;
  }
  .sitefooter__close .langtoggle {
    margin-top: var(--space-2);
  }
  .sitefooter__maxim {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: 1.1;
    color: var(--ink);
  }
  .sitefooter__legal {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  /* --- 4 barres finales (echo du logo) ---
     Draw-in au viewport via [data-footer-mark].is-appeared — ajouté par le JS
     reveal.ts (l'élément porte data-appear). Les barres poussent une à une
     avec un léger crescendo de hauteur. */
  .sitefooter__mark {
    display: flex;
    gap: clamp(8px, 1.2vw, 14px);
    align-items: flex-end;
    justify-content: center;
    margin-top: clamp(3rem, 5vw, 5rem);
    height: clamp(80px, 10vw, 120px);
  }
  .sitefooter__bar {
    width: clamp(6px, 0.7vw, 10px);
    background: var(--ink);
    transform-origin: 50% 100%;
    transform: scaleY(0);
    transition: transform 780ms var(--ease-editorial);
  }
  .sitefooter__bar:nth-child(1) { height: 60%;  transition-delay: 120ms; }
  .sitefooter__bar:nth-child(2) { height: 78%;  transition-delay: 220ms; }
  .sitefooter__bar:nth-child(3) { height: 92%;  transition-delay: 320ms; }
  .sitefooter__bar:nth-child(4) { height: 100%; transition-delay: 420ms; }

  .sitefooter__mark.is-appeared .sitefooter__bar {
    transform: scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .sitefooter__bar { transform: scaleY(1); transition: none; }
  }

  @media (max-width: 720px) {
    .sitefooter__grid {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .sitefooter__nav {
      justify-content: flex-start;
    }
    .sitefooter__close {
      text-align: left;
      justify-self: start;
    }
  }
</style>
