---
// § 04 — Dona
// Présentation du coach IA. Pull-quote (voix de Dona) + tarifs.
// Plus de Pomodoro ici — ça reste dans TheWork.
---

<section class="focus" id="dona" data-focus>
  <div class="focus__inner">

    <span class="eyebrow focus__eyebrow" data-appear>
      <span data-lang="en">Dona</span>
      <span data-lang="fr">Dona</span>
    </span>

    <h2 class="focus__title" data-appear data-appear-delay="100">
      <span data-lang="en">Dona.<br /><em>An AI that reads your log.</em></span>
      <span data-lang="fr">Dona.<br /><em>Une IA qui lit ton carnet.</em></span>
    </h2>

    <p class="focus__lede" data-appear data-appear-delay="240">
      <span data-lang="en">A measured voice. Answers in context. Doesn't flatter.</span>
      <span data-lang="fr">Une voix tempérée. Répond en contexte. Ne flatte pas.</span>
    </p>

    <!-- Tarifs Dona — table centrée, séparée par un filet ink. -->
    <div class="focus__plan" data-appear data-appear-delay="520">
      <div class="focus__plan-head">
        <span class="focus__plan-tag" data-lang="en">Three tiers</span>
        <span class="focus__plan-tag" data-lang="fr">Trois formules</span>
      </div>

      <ul class="focus__tiers" role="list" data-appear-group>
        <li class="focus__tier" data-appear>
          <span class="focus__tier-name">Essential</span>
          <span class="focus__tier-price">1,99 <em>€/mo</em></span>
        </li>
        <li class="focus__tier focus__tier--star" data-appear>
          <span class="focus__tier-name">
            Pro <span class="focus__tier-star" aria-label="recommended">★</span>
          </span>
          <span class="focus__tier-price">3,99 <em>€/mo</em></span>
        </li>
        <li class="focus__tier" data-appear>
          <span class="focus__tier-name">Unlimited</span>
          <span class="focus__tier-price">6,99 <em>€/mo</em></span>
        </li>
      </ul>

      <p class="focus__plan-body">
        <span data-lang="en">Subscribe from inside the app.</span>
        <span data-lang="fr">Abonnement depuis l'app.</span>
      </p>
      <p class="focus__plan-edu">
        <span data-lang="en"><strong>Students · −40%</strong> — from 1,19 €/mo.</span>
        <span data-lang="fr"><strong>Étudiants · −40 %</strong> — dès 1,19 €/mois.</span>
      </p>
    </div>

    <a class="focus__cta" href="#get-started" data-appear data-appear-delay="700">
      <span class="focus__cta-inner">
        <span data-lang="en">See the plan</span>
        <span data-lang="fr">Voir le plan</span>
        <span class="focus__arrow" aria-hidden="true">↓</span>
      </span>
    </a>

  </div>
</section>

<style>
  .focus {
    position: relative;
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: clamp(6rem, 10vw, 10rem) var(--gutter);
  }

  .focus__inner {
    width: 100%;
    max-width: var(--col-narrow);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .focus__eyebrow { color: var(--mute); }

  /* --- Title : hero typographique --- */
  .focus__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw + 1rem, 7rem);
    font-weight: 200;
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
    max-width: 16ch;
    padding-bottom: 0.08em;
    margin: 0;
  }
  .focus__title em { font-style: italic; color: var(--mute); }

  /* --- Lede --- */
  .focus__lede {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1vw + 0.95rem, 1.6rem);
    line-height: 1.4;
    color: var(--mute);
    font-style: italic;
    max-width: 36ch;
    margin: 0;
  }

  /* --- Plan Dona : table centrée --- */
  .focus__plan {
    width: 100%;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--rule-strong);
  }

  .focus__plan-head {
    display: flex;
    justify-content: center;
  }
  .focus__plan-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  .focus__tiers {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-3);
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
  }
  .focus__tier {
    position: relative;
    isolation: isolate;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-3);
    border-bottom: 1px solid var(--rule);
    transition: color var(--dur-base) var(--ease-out);
  }
  .focus__tier::before {
    content: "";
    position: absolute;
    inset: 0 calc(var(--space-3) * -1);
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-base) var(--ease-editorial);
    z-index: -1;
  }
  .focus__tier:hover { color: var(--paper); }
  .focus__tier:hover::before { transform: scaleX(1); }
  .focus__tier:hover .focus__tier-name,
  .focus__tier:hover .focus__tier-price { color: var(--paper); }
  .focus__tier:hover .focus__tier-star { color: var(--paper); }
  .focus__tier:hover .focus__tier-price em { color: var(--paper); opacity: 0.75; }

  .focus__tier-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .focus__tier-star {
    font-size: 0.9em;
    line-height: 1;
    color: var(--ink);
  }
  .focus__tier-price {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 1.5vw + 0.75rem, 2.25rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: var(--tracking-tight);
  }
  .focus__tier-price em {
    font-size: 0.42em;
    font-style: normal;
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    margin-left: var(--space-1);
    vertical-align: baseline;
  }

  .focus__plan-body {
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: 1.45;
    color: var(--mute);
    margin: 0;
    text-align: center;
  }

  .focus__plan-edu {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    margin: 0;
    text-align: center;
  }
  .focus__plan-edu strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* --- CTA --- */
  .focus__cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: transparent;
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
    box-shadow: var(--ring);
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
    will-change: transform;
  }
  .focus__cta:hover { background: var(--ink); color: var(--paper); }
  .focus__cta:hover .focus__arrow { transform: translateY(3px); }
  .focus__cta:active { transform: scale(0.97); }
  .focus__cta-inner {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    line-height: 1;
    white-space: nowrap;
  }
  .focus__arrow {
    display: inline-block;
    line-height: 1;
    font-size: 1.1em;
    transition: transform var(--dur-base) var(--ease-out);
  }

  @media (max-width: 540px) {
    .focus__rhythm { gap: 0.5rem; padding-inline: var(--space-4); }
  }
</style>
