---
// § 04 — Focus
// Tore 3D OGL + présentation Dona Plus (coach IA inclus).
---

<section class="focus" data-focus>
  <div class="focus__grid">

    <div class="focus__stage">
      <canvas class="focus__canvas" data-focus-canvas aria-hidden="true"></canvas>
      <span class="focus__caption">
        <span class="focus__dot" aria-hidden="true"></span>
        25 · 05 · 25 · 05
      </span>
    </div>

    <div class="focus__text">
      <span class="eyebrow" data-lang="en">Focus</span>
      <span class="eyebrow" data-lang="fr">Focus</span>

      <h2 class="focus__title">
        <span data-lang="en">A torus.<br /><em>Twenty-five minutes.</em><br />Five. Again.</span>
        <span data-lang="fr">Un tore.<br /><em>Vingt-cinq minutes.</em><br />Cinq. Encore.</span>
      </h2>

      <p class="focus__lede">
        <span data-lang="en">The session imposes itself. You yield. Manager doesn't negotiate.</span>
        <span data-lang="fr">La session s'impose. Tu t'y plies. Manager ne négocie pas.</span>
      </p>

      <div class="focus__offer">
        <div class="focus__plan">
          <div class="focus__plan-head">
            <span class="focus__plan-tag" data-lang="en">Dona · AI coach</span>
            <span class="focus__plan-tag" data-lang="fr">Dona · Coach IA</span>
            <span class="focus__plan-price">2,49 <em>€/mo</em></span>
          </div>
          <p class="focus__plan-body">
            <span data-lang="en">Reads your log, answers with context. 500 messages / month. 7-day trial — no card.</span>
            <span data-lang="fr">Lit ton carnet, répond en contexte. 500 messages / mois. 7 jours d'essai — sans carte.</span>
          </p>
        </div>

        <a class="focus__plan-more" href="#get-started" data-magnetic>
          <span class="hbtn__inner" data-magnetic-inner>
            <span data-lang="en">See the plan</span>
            <span data-lang="fr">Voir le plan</span>
            <span class="focus__arrow" aria-hidden="true">↓</span>
          </span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .focus {
    position: relative;
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding-block: clamp(6rem, 10vw, 10rem);
  }

  .focus__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: center;
    gap: clamp(3rem, 7vw, 7rem);
    width: 100%;
    max-width: var(--col-max);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  /* --- Stage canvas --- */
  .focus__stage {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 640px;
    justify-self: center;
  }
  .focus__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .focus__caption {
    position: absolute;
    left: 0; bottom: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }
  .focus__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ink);
    animation: focus-beat 1.4s ease-in-out infinite;
  }
  @keyframes focus-beat {
    0%, 100% { transform: scale(1);   opacity: 1; }
    50%      { transform: scale(1.3); opacity: 0.55; }
  }

  /* --- Text column --- */
  .focus__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 34rem;
  }

  .focus__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.5vw + 0.5rem, 5.25rem);
    font-weight: 200;
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
  }
  .focus__title em { font-style: italic; color: var(--mute); }

  .focus__lede {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1vw + 0.75rem, 1.6rem);
    line-height: 1.3;
    color: var(--mute);
    font-style: italic;
    max-width: 30ch;
  }

  /* --- Dona Plus plan --- */
  .focus__offer {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: flex-start;
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }

  .focus__plan {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
    max-width: 40ch;
  }

  .focus__plan-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .focus__plan-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }

  .focus__plan-price {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 3.5vw + 0.5rem, 3.5rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: var(--tracking-tight);
    margin-left: auto;
  }
  .focus__plan-price em {
    font-size: 0.4em;
    font-style: normal;
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    margin-left: var(--space-1);
    vertical-align: middle;
  }

  .focus__plan-body {
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: 1.45;
    color: var(--mute);
  }

  /* --- "See the plan" CTA --- */
  .focus__plan-more {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: transparent;
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    box-shadow: var(--ring);
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
    will-change: transform;
  }
  .focus__plan-more:hover { background: var(--ink); color: var(--paper); }
  .focus__plan-more:active { transform: scale(0.97); }
  .focus__arrow { margin-left: var(--space-2); }

  /* --- Mobile --- */
  @media (max-width: 860px) {
    .focus__grid { grid-template-columns: 1fr; }
    .focus__stage { max-width: 420px; }
  }
</style>
