---
// § 06 — Get started / Commencer
// Bilingue via data-lang. Liens download tirés de l'API GitHub au build.

import { getLatestRelease } from "~/lib/releases";

const { version: VERSION, winUrl: WIN_URL, debUrl: DEB_URL } = await getLatestRelease();
const AUR_PKG = "manager-bin";
const GH_RELEASES = "https://github.com/JAuxance/manager-releases";
---

<section class="gs" id="get-started" data-gs>
  <div class="gs__head">
    <span class="eyebrow" data-appear>
      <span data-lang="en">Get started</span>
      <span data-lang="fr">Commencer</span>
    </span>

    <h2 class="gs__title" data-appear data-appear-delay="120">
      <span data-lang="en">Four steps. <em>No account.</em></span>
      <span data-lang="fr">Quatre étapes. <em>Aucun compte.</em></span>
    </h2>

    <p class="gs__lede" data-appear data-appear-delay="260">
      <span data-lang="en">Local-first desktop app. Your log lives on your machine.</span>
      <span data-lang="fr">App desktop local-first. Ton carnet vit sur ta machine.</span>
    </p>
  </div>

  <ol class="gs__steps" data-appear-group>

    <!-- Step 01 — Download -->
    <li class="gs__step" data-appear>
      <div class="gs__step-head">
        <span class="gs__num">Nº 01</span>
        <h3 class="gs__step-title">
          <span data-lang="en">Download</span>
          <span data-lang="fr">Télécharger</span>
        </h3>
      </div>

      <div class="gs__dls">
        <a class="gs__dl gs__dl--primary" href={WIN_URL}>
          <span class="gs__dl-plat">Windows</span>
          <span class="gs__dl-ext">.exe · v{VERSION}</span>
        </a>

        <a class="gs__dl" href={DEB_URL}>
          <span class="gs__dl-plat">Linux</span>
          <span class="gs__dl-ext">.deb · v{VERSION}</span>
        </a>

        <div class="gs__dl gs__dl--code" aria-label="Arch Linux AUR">
          <span class="gs__dl-plat">Arch · AUR</span>
          <code class="gs__dl-cmd">yay -S {AUR_PKG}</code>
        </div>

        <div class="gs__dl gs__dl--soon">
          <span class="gs__dl-plat">macOS</span>
          <span class="gs__dl-ext" data-lang="en">Coming soon</span>
          <span class="gs__dl-ext" data-lang="fr">Bientôt</span>
        </div>
      </div>
    </li>

    <!-- Step 02 — Install -->
    <li class="gs__step" data-appear>
      <div class="gs__step-head">
        <span class="gs__num">Nº 02</span>
        <h3 class="gs__step-title">
          <span data-lang="en">Install</span>
          <span data-lang="fr">Installer</span>
        </h3>
      </div>
      <p class="gs__step-body">
        <span data-lang="en">Native executable. No account. No cloud required.</span>
        <span data-lang="fr">Exécutable natif. Aucun compte. Aucun cloud requis.</span>
      </p>
    </li>

    <!-- Step 03 — First launch -->
    <li class="gs__step" data-appear>
      <div class="gs__step-head">
        <span class="gs__num">Nº 03</span>
        <h3 class="gs__step-title">
          <span data-lang="en">Start the series</span>
          <span data-lang="fr">Commencer la série</span>
        </h3>
      </div>
      <p class="gs__step-body">
        <span data-lang="en">First launch creates your log. Day&nbsp;1 is today.</span>
        <span data-lang="fr">La première ouverture crée ton carnet. Jour&nbsp;1 = aujourd'hui.</span>
      </p>
    </li>

    <!-- Step 04 — Dona (optional, just a pointer — pricing lives in #dona) -->
    <li class="gs__step" data-appear>
      <div class="gs__step-head">
        <span class="gs__num">Nº 04</span>
        <h3 class="gs__step-title">
          <span data-lang="en">Dona <em>(optional)</em></span>
          <span data-lang="fr">Dona <em>(optionnel)</em></span>
        </h3>
      </div>

      <div class="gs__step-content">
        <p class="gs__step-body">
          <span data-lang="en">Want an AI coach that reads your log? Bring your own API key — or subscribe in-app.</span>
          <span data-lang="fr">Envie d'un coach IA qui lit ton carnet ? Clé API perso — ou abonnement dans l'app.</span>
        </p>
        <a class="gs__inline-link" href="#dona">
          <span data-lang="en">See Dona plans</span>
          <span data-lang="fr">Voir les formules Dona</span>
          <span aria-hidden="true">↑</span>
        </a>
      </div>
    </li>

  </ol>

  <!-- FAQ -->
  <div class="gs__faq">
    <h3 class="gs__faq-title" data-appear>
      <span data-lang="en">Four questions</span>
      <span data-lang="fr">Quatre questions</span>
    </h3>

    <dl class="gs__faq-list" data-appear-group>
      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">What runs it?</dt>
        <dt data-lang="fr">Sur quoi ça tourne ?</dt>
        <dd data-lang="en">Windows 10/11 (.exe, NSIS) and Linux (.deb for Debian/Ubuntu, AUR for Arch: <code>yay -S manager-bin</code>). macOS is in progress. Install footprint ≈ 50 MB.</dd>
        <dd data-lang="fr">Windows 10/11 (.exe, NSIS) et Linux (.deb pour Debian/Ubuntu, AUR pour Arch&nbsp;: <code>yay -S manager-bin</code>). macOS en cours. ≈ 50&nbsp;Mo installé.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">Where are my entries stored?</dt>
        <dt data-lang="fr">Où sont stockées mes entrées ?</dt>
        <dd data-lang="en">Locally, in a SQLite file on your machine. Nothing leaves it — unless you enable Dona (messages go to the AI provider) or sync (encrypted to Supabase). Both are off by default.</dd>
        <dd data-lang="fr">Localement, dans un fichier SQLite sur ta machine. Rien n'en sort — sauf si tu actives Dona (les messages partent vers le provider IA) ou la sync (chiffré vers Supabase). Les deux sont désactivés par défaut.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">Does it update itself?</dt>
        <dt data-lang="fr">Est-ce qu'il se met à jour tout seul ?</dt>
        <dd data-lang="en">Yes — signed auto-updater checks on launch and every 4h. Updates are verified with minisign. On Arch, <code>yay -Syu</code> handles it instead.</dd>
        <dd data-lang="fr">Oui — updater signé au lancement et toutes les 4h. Chaque mise à jour est vérifiée par minisign. Sur Arch, <code>yay -Syu</code> s'en charge à la place.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">Does it work offline?</dt>
        <dt data-lang="fr">Ça marche hors-ligne ?</dt>
        <dd data-lang="en">Fully. The app is local-first. Sync and Dona are the only parts that need the network, and both are optional.</dd>
        <dd data-lang="fr">Totalement. L'app est local-first. Seules la sync et Dona utilisent le réseau, et les deux sont optionnelles.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">Can I export my data?</dt>
        <dt data-lang="fr">Puis-je exporter mes données ?</dt>
        <dd data-lang="en">Yes. Your entries live in a SQLite file — portable, readable, yours to move. Nothing proprietary.</dd>
        <dd data-lang="fr">Oui. Tes entrées vivent dans un fichier SQLite — portable, lisible, à toi. Rien de propriétaire.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">Which languages?</dt>
        <dt data-lang="fr">Quelles langues ?</dt>
        <dd data-lang="en">English and French. The whole interface — including the morning ritual and Dona — switches instantly.</dd>
        <dd data-lang="fr">Anglais et français. Toute l'interface — rituel du matin et Dona inclus — bascule instantanément.</dd>
      </div>

      <div class="gs__faq-item" data-appear>
        <dt data-lang="en">macOS when?</dt>
        <dt data-lang="fr">macOS quand ?</dt>
        <dd data-lang="en">Coming. Follow <a href={GH_RELEASES} target="_blank" rel="noopener noreferrer">releases</a> for updates.</dd>
        <dd data-lang="fr">Bientôt. Suis les <a href={GH_RELEASES} target="_blank" rel="noopener noreferrer">releases</a> pour l'avancée.</dd>
      </div>
    </dl>
  </div>

</section>

<style>
  .gs {
    position: relative;
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: clamp(5rem, 8vw, 8rem) var(--gutter);
  }

  /* --- Head --- */
  .gs__head {
    max-width: var(--col-max);
    margin: 0 auto clamp(3rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .gs__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.5vw + 0.5rem, 5.5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    max-width: 18ch;
    padding-bottom: 0.08em;
  }
  .gs__title em { font-style: italic; color: var(--mute); }
  .gs__lede {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1vw + 0.75rem, 1.4rem);
    font-style: italic;
    color: var(--mute);
    max-width: 40ch;
  }

  /* --- Steps --- */
  .gs__steps {
    max-width: var(--col-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .gs__step {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: clamp(2rem, 4vw, 4rem);
    padding: clamp(2rem, 4vw, 3rem) 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .gs__step:last-of-type { border-bottom: 1px solid var(--rule); }

  .gs__step-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .gs__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
  }
  .gs__step-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.5vw + 0.75rem, 2.5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }
  .gs__step-title em { font-style: italic; color: var(--mute); font-size: 0.75em; }

  .gs__step-body {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.75vw + 0.9rem, 1.35rem);
    line-height: 1.45;
    color: var(--ink);
  }
  .gs__step-body strong { font-weight: 400; color: var(--ink); }
  .gs__step-fine {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--mute);
    margin-top: var(--space-4);
    letter-spacing: 0.02em;
  }

  /* Inline pointer link (Step 04 → #dona) */
  .gs__inline-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    width: fit-content;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
  }
  .gs__inline-link:hover {
    color: var(--accent-hover);
    border-color: var(--accent-hover);
  }
  .gs__inline-link:active { transform: translateY(1px); }

  /* --- Download buttons (step 01) --- */
  .gs__dls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .gs__dl {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-4) var(--space-5, 1.25rem);
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    box-shadow: var(--ring);
    overflow: hidden;
    transition:
      color var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
    will-change: transform;
    min-width: 160px;
  }
  /* Ink sweep — un rideau d'encre qui vient depuis le bas sur hover. */
  .gs__dl::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateY(100%);
    transition: transform var(--dur-base) var(--ease-editorial);
    z-index: -1;
  }
  .gs__dl:hover { color: var(--paper); }
  .gs__dl:hover::before { transform: translateY(0); }
  .gs__dl:active { transform: scale(0.97); }

  .gs__dl--primary {
    background: var(--accent);
    color: var(--accent-ink);
    box-shadow: inset 0 0 0 1px var(--accent);
    transition:
      background var(--dur-base) var(--ease-editorial),
      color var(--dur-base) var(--ease-editorial),
      box-shadow var(--dur-base) var(--ease-editorial),
      transform var(--dur-press) var(--ease-out);
  }
  .gs__dl--primary::before { display: none; }
  .gs__dl--primary:hover { background: var(--accent-hover); box-shadow: inset 0 0 0 1px var(--accent-hover), 0 14px 36px -14px var(--accent-soft); }

  .gs__dl--soon {
    color: var(--mute);
    box-shadow: inset 0 0 0 1px var(--rule-strong);
    cursor: not-allowed;
  }
  .gs__dl--soon::before { display: none; }
  .gs__dl--soon:hover { background: transparent; color: var(--mute); transform: none; }

  .gs__dl--code {
    background: var(--paper-sunk);
    box-shadow: inset 0 0 0 1px var(--rule);
    cursor: default;
  }
  .gs__dl--code::before { display: none; }
  .gs__dl--code:hover { background: var(--paper-sunk); color: var(--ink); transform: none; }

  .gs__dl-plat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .gs__dl-ext {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    opacity: 0.65;
  }
  .gs__dl-cmd {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink);
    background: transparent;
    padding: 0;
    letter-spacing: 0;
    text-transform: none;
  }

  /* --- Step 04 pricing tiers --- */
  .gs__step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .gs__tiers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
    max-width: 38rem;
  }
  .gs__tier {
    position: relative;
    isolation: isolate;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-2);
    margin-inline: calc(var(--space-2) * -1);
    border-bottom: 1px solid var(--rule);
    transition: color var(--dur-base) var(--ease-out);
  }
  .gs__tier::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-base) var(--ease-editorial);
    z-index: -1;
  }
  .gs__tier:hover { color: var(--paper); }
  .gs__tier:hover::before { transform: scaleX(1); }
  .gs__tier:hover .gs__tier-name,
  .gs__tier:hover .gs__tier-price { color: var(--paper); }
  .gs__tier:hover .gs__tier-price em { color: var(--paper); opacity: 0.75; }

  /* Pro tier — étoile or pour signaler "recommandé" sans casser la rangée. */
  .gs__tier--star .gs__tier-name [aria-label="recommended"] {
    color: var(--accent);
    margin-left: var(--space-1);
    font-size: 0.85em;
    line-height: 1;
  }
  .gs__tier--star:hover .gs__tier-name [aria-label="recommended"] {
    color: var(--paper);
  }
  .gs__tier-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .gs__tier-price {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.5vw + 0.75rem, 2rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: var(--tracking-tight);
  }
  .gs__tier-price em {
    font-size: 0.42em;
    font-style: normal;
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    margin-left: var(--space-1);
    vertical-align: baseline;
  }
  .gs__tier-edu {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--mute);
    line-height: 1.5;
    margin: 0;
    max-width: 38rem;
  }
  .gs__tier-edu strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* --- FAQ --- */
  .gs__faq {
    max-width: var(--col-max);
    margin: clamp(4rem, 7vw, 6rem) auto 0;
  }
  .gs__faq-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem);
    font-weight: 200;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-8);
  }

  .gs__faq-list {
    display: flex;
    flex-direction: column;
  }
  .gs__faq-item {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: clamp(2rem, 4vw, 4rem);
    padding: var(--space-6) var(--space-4);
    margin-inline: calc(var(--space-4) * -1);
    border-top: 1px solid var(--rule);
    transition: background var(--dur-base) var(--ease-out);
  }
  .gs__faq-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--ink);
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform var(--dur-base) var(--ease-editorial);
  }
  .gs__faq-item:hover::before { transform: scaleY(1); }
  .gs__faq-item:last-child { border-bottom: 1px solid var(--rule); }

  .gs__faq-item dt {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.75vw + 0.9rem, 1.3rem);
    font-weight: 400;
    line-height: 1.3;
  }
  .gs__faq-item dd {
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--mute);
    font-style: italic;
    margin: 0;
  }
  .gs__faq-item dd a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-soft);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--dur-fast) var(--ease-out);
  }
  .gs__faq-item dd a:hover { text-decoration-color: var(--accent); }

  .gs__faq-item dd code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    font-style: normal;
    letter-spacing: 0.02em;
    background: var(--paper-sunk);
    padding: 1px 6px;
    border: 1px solid var(--rule);
    color: var(--ink);
  }

  /* --- Mobile --- */
  @media (max-width: 720px) {
    .gs__step,
    .gs__faq-item {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .gs__dl { min-width: 0; flex: 1 1 140px; }
  }
</style>
