---
import Logo from "~/components/Logo.astro";
import ScrollCue from "~/components/ui/ScrollCue.astro";
import { getLatestRelease } from "~/lib/releases";

const { winUrl: WIN_URL, debUrl: DEB_URL } = await getLatestRelease();
---

<section class="hero" data-hero>
  <h1 class="visually-hidden">Manager — Day counter, focus timer, journal.</h1>

  <div class="hero__stage">
    <div class="hero__logo-wrap" data-hero-logo-wrap>
      <Logo animated class="hero__logo" />
    </div>

    <span class="hero__free" data-reveal-free aria-label="Free">
      <span class="hero__free-dot" aria-hidden="true"></span>
      <span data-lang="en">Free</span>
      <span data-lang="fr">Gratuit</span>
    </span>

    <div class="hero__actions" data-reveal-actions>
      <a class="hbtn hbtn--solid" href={WIN_URL} data-magnetic>
        <span class="hbtn__inner" data-magnetic-inner>
          <span class="hbtn__label" data-lang="en">Download</span>
          <span class="hbtn__label" data-lang="fr">Télécharger</span>
          <span class="hbtn__plat">Windows · .exe</span>
        </span>
      </a>
      <a class="hbtn hbtn--ghost" href={DEB_URL} data-magnetic>
        <span class="hbtn__inner" data-magnetic-inner>
          <span class="hbtn__label">Linux</span>
          <span class="hbtn__plat">.deb</span>
        </span>
      </a>
      <span class="hbtn hbtn--soon" aria-disabled="true">
        <span class="hbtn__inner">
          <span class="hbtn__label">macOS</span>
          <span class="hbtn__plat" data-lang="en">soon</span>
          <span class="hbtn__plat" data-lang="fr">bientôt</span>
        </span>
      </span>
    </div>

    <a class="hero__start" href="#get-started" data-reveal-start>
      <span class="hero__start-label">
        <span data-lang="en">Get started</span>
        <span data-lang="fr">Commencer</span>
      </span>
      <span class="hero__start-line" aria-hidden="true"></span>
      <span class="hero__start-arrow" aria-hidden="true">↓</span>
    </a>
  </div>

  <div class="hero__cue">
    <ScrollCue />
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: grid;
    grid-template-rows: 1fr auto;
    padding: var(--gutter);
    isolation: isolate;
  }

  .hero__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(3rem, 7vw, 6rem);
    text-align: center;
  }

  .hero__logo-wrap {
    perspective: 1100px;
    width: clamp(260px, 32vw, 460px);
    aspect-ratio: 1 / 1;
    will-change: transform;
  }

  /* Flash-guard : le HTML inline rend les barres + la diagonale à leur
     position finale avant que le JS d'intro n'ait placé les offsets off-screen.
     On les masque jusqu'à ce que hero.ts ajoute .is-ready sur le wrap. */
  .hero__logo-wrap:not(.is-ready) :global([data-logo-bar]),
  .hero__logo-wrap:not(.is-ready) :global([data-logo-diag]) {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__logo-wrap :global([data-logo-bar]),
    .hero__logo-wrap :global([data-logo-diag]) {
      opacity: 1;
    }
  }

  /* --- Get started editorial link --- */
  .hero__start {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    transition: transform var(--dur-press) var(--ease-out);
    will-change: transform;
  }
  .hero__start:active { transform: scale(0.97); }

  .hero__start-label { line-height: 1; }

  .hero__start-line {
    display: inline-block;
    width: clamp(3rem, 5vw, 4.5rem);
    height: 1px;
    background: var(--ink);
    transition: width var(--dur-base) var(--ease-out);
  }
  .hero__start:hover .hero__start-line {
    width: clamp(4.5rem, 8vw, 7rem);
  }

  .hero__start-arrow {
    font-size: 1em;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .hero__start:hover .hero__start-arrow {
    transform: translateY(3px);
  }

  /* --- Free badge --- */
  .hero__free {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1;
    /* Annule une partie du gap du stage pour ne laisser qu'un petit espace
       (~1.25rem) entre Free et les boutons Download. */
    margin-bottom: calc(var(--space-6) - clamp(3rem, 7vw, 6rem));
  }
  .hero__free-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ink);
    display: inline-block;
    animation: hero-free-pulse 2.2s ease-in-out infinite;
  }
  @keyframes hero-free-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.35); opacity: 0.55; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__free-dot { animation: none; }
  }

  /* --- Download CTAs --- */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .hbtn {
    --pad-x: var(--space-4);
    --pad-y: var(--space-3);
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: var(--pad-y) var(--pad-x);
    border-radius: var(--radius);
    text-decoration: none;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
    will-change: transform;
  }
  .hbtn:active  { transform: scale(0.97); }
  .hbtn--soon:active { transform: none; }
  .hbtn__inner {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    will-change: transform;
  }
  .hbtn__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .hbtn__plat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    opacity: 0.65;
  }
  /* Télécharger = primary → padding horizontal plus généreux pour la prominence.
     On ne touche pas le padding vertical pour ne pas casser la ligne des 3 CTAs. */
  .hbtn--solid  {
    background: var(--ink);
    color: var(--paper);
    --pad-x: var(--space-6);
  }
  .hbtn--solid:hover  { background: var(--paper); color: var(--ink); box-shadow: var(--ring); }
  .hbtn--ghost  { background: transparent; color: var(--ink); box-shadow: var(--ring); }
  .hbtn--ghost:hover  { background: var(--ink); color: var(--paper); }
  .hbtn--soon   { background: transparent; color: var(--mute); box-shadow: inset 0 0 0 1px var(--rule-strong); cursor: not-allowed; }

  /* --- Scroll cue — ligne du bas dans la grille, pas absolute --- */
  .hero__cue {
    justify-self: center;
    align-self: end;
    padding-top: var(--space-4);
  }

  @media (max-width: 540px) {
    .hero__logo-wrap { width: min(62vw, 280px); }

    /* Stack CTAs verticalement — Télécharger reste primary par son fond ink */
    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      max-width: 260px;
      gap: var(--space-2);
    }
    .hbtn {
      justify-content: center;
      padding-block: var(--space-4);
    }
    .hbtn__inner {
      align-items: center;
    }
  }
</style>
