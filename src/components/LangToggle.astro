---
interface Props {
  variant?: "inline" | "solid";
}
const { variant = "inline" } = Astro.props;
---

<div
  class:list={["langtoggle", `langtoggle--${variant}`]}
  role="group"
  aria-label="Language / Langue"
>
  <button class="langtoggle__btn" data-lang-set="en" aria-pressed="true">EN</button>
  <span class="langtoggle__sep" aria-hidden="true">·</span>
  <button class="langtoggle__btn" data-lang-set="fr" aria-pressed="false">FR</button>
</div>

<style>
  .langtoggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }

  .langtoggle__btn {
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-press) var(--ease-out);
  }
  .langtoggle__btn:active { transform: scale(0.97); }

  /* --- inline (footer, inline dans le flow) : ink muted → ink --- */
  .langtoggle--inline .langtoggle__btn { color: var(--mute); }
  .langtoggle--inline .langtoggle__btn:hover { color: var(--ink); }
  .langtoggle--inline .langtoggle__btn[aria-pressed="true"] { color: var(--ink); }
  .langtoggle--inline .langtoggle__sep { color: var(--rule-strong); }

  /* --- solid (badge top-left, fond ink) : paper muted → paper --- */
  .langtoggle--solid .langtoggle__btn { color: var(--paper); opacity: 0.5; }
  .langtoggle--solid .langtoggle__btn:hover { opacity: 1; }
  .langtoggle--solid .langtoggle__btn[aria-pressed="true"] { opacity: 1; }
  .langtoggle--solid .langtoggle__sep { color: var(--paper); opacity: 0.3; }
</style>
